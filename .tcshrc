
#init commands
#scl enable devtoolset-6 git19 perl516 python27 tcsh

# User Aliases
alias v           'xterm -e vim -T xterm-256color\!*'
alias g           'gvim \!*'
alias p           'pwd'
alias c           'clear'
alias ..          'cd ..'
alias .           'pwd'
#Git
alias gd          'git difftool --no-prompt -t tkdiff \!*'
alias gco         'git checkout -- \!*'
alias gst         'git status -suno'
alias gr          'egrep --color=auto'
